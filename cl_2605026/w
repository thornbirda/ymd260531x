최종 코드
vba

Sub ExtractKeyValues()
    Dim wsTarget As Worksheet
    Dim wsOutput As Worksheet
    Dim cell As Range
    Dim outRow As Long
    Dim sheetName As String
    Dim searchKey As String
    Dim re As Object
    Dim matches As Object
    Dim m As Object

    Set wsOutput = ThisWorkbook.Sheets("W")
    sheetName = Trim(wsOutput.Range("F1").Value)  ' 탐색 대상 시트명
    searchKey = Trim(wsOutput.Range("G1").Value)  ' 찾을 키

    ' 입력값 검증
    If sheetName = "" Or searchKey = "" Then
        MsgBox "F1(시트명)과 G1(키)를 입력하세요."
        Exit Sub
    End If

    ' 대상 시트 확인
    On Error Resume Next
    Set wsTarget = ThisWorkbook.Sheets(sheetName)
    On Error GoTo 0
    If wsTarget Is Nothing Then
        MsgBox "시트를 찾을 수 없습니다: " & sheetName
        Exit Sub
    End If

    ' 정규식 설정
    ' 패턴: 지정된 키 + 공백* + == + 공백* + 값(\S+)
    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = False
    re.Pattern = "(?:^|\s)(" & searchKey & ")\s*==\s*(\S+)"

    ' 출력 초기화
    wsOutput.Range("G11:H1000").ClearContents
    outRow = 11

    ' 대상 시트 전체 셀 순회
    For Each cell In wsTarget.UsedRange
        Dim cellVal As String
        cellVal = Trim(CStr(cell.Value))
        If Len(cellVal) = 0 Then GoTo NextCell

        Set matches = re.Execute(cellVal)
        For Each m In matches
            wsOutput.Cells(outRow, 7).Value = m.SubMatches(0)  ' G열: 키
            wsOutput.Cells(outRow, 8).Value = m.SubMatches(1)  ' H열: 키값
            outRow = outRow + 1
        Next m

NextCell:
    Next cell

    If outRow = 11 Then
        MsgBox "'" & searchKey & "' 키를 찾지 못했습니다."
    Else
        MsgBox "완료! 총 " & (outRow - 11) & "개 추출"
    End If
End Sub

