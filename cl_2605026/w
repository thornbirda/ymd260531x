Sub ExtractKeyValues()
    Dim wsTarget As Worksheet
    Dim wsOutput As Worksheet
    Dim cell As Range
    Dim pairs() As String
    Dim pair() As String
    Dim i As Long
    Dim outRow As Long
    Dim sheetName As String

    Set wsOutput = ThisWorkbook.Sheets("W")
    sheetName = wsOutput.Range("H1").Value

    ' 대상 시트 확인
    On Error Resume Next
    Set wsTarget = ThisWorkbook.Sheets(sheetName)
    On Error GoTo 0
    If wsTarget Is Nothing Then
        MsgBox "시트를 찾을 수 없습니다: " & sheetName
        Exit Sub
    End If

    ' 출력 초기화
    wsOutput.Range("H11:I1000").ClearContents
    outRow = 11

    ' 전체 셀 순회
    For Each cell In wsTarget.UsedRange
        If InStr(cell.Value, "=") > 0 Then
            ' & 구분자로 분리 (구분자 다르면 여기 수정)
            pairs = Split(cell.Value, "&")
            For i = 0 To UBound(pairs)
                If InStr(pairs(i), "=") > 0 Then
                    pair = Split(pairs(i), "=", 2)
                    wsOutput.Cells(outRow, 8).Value = Trim(pair(0))  ' H열: 키
                    wsOutput.Cells(outRow, 9).Value = Trim(pair(1))  ' I열: 값
                    outRow = outRow + 1
                End If
            Next i
        End If
    Next cell

    MsgBox "완료! 총 " & (outRow - 11) & "개 추출"
End Sub

