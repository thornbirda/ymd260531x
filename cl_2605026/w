' 현재시트 E2 입력 문자열 → 현재시트 전체 하이퍼링크 주소 검색
' 짝수열 검출: W시트 H11~I (웹주소/짝셀값), 홀수열 검출: 한줄띄고 이어서 출력
Sub fnd_wL()
    Dim wsOutput As Worksheet
    Dim wsInput As Worksheet
    Dim cell As Range
    Dim keyword As String
    Dim outRow As Long
    Dim outRowOdd As Long
    Dim url As String
    Dim colNum As Long

    ' 정상(짝수열) 임시저장
    Dim normalArr() As String
    Dim normalCount As Long
    ReDim normalArr(1 To 10000, 1 To 2)

    ' 오염(홀수열) 임시저장
    Dim oddArr() As String
    Dim oddCount As Long
    ReDim oddArr(1 To 10000, 1 To 2)

    Set wsOutput = ThisWorkbook.Sheets("w")
    Set wsInput = ActiveSheet

    keyword = Trim(wsInput.Range("E2").Value)

    If keyword = "" Then
        MsgBox "E2에 검색할 주소 문자열을 입력하세요."
        Exit Sub
    End If

    wsOutput.Range("H11:I10000").ClearContents
    normalCount = 0
    oddCount = 0

    Application.ScreenUpdating = False

    For Each cell In wsInput.UsedRange
        If cell.Hyperlinks.Count > 0 Then
            url = cell.Hyperlinks(1).Address
            If InStr(url, keyword) > 0 Then
                colNum = cell.Column
                Dim pairVal As String
                pairVal = wsInput.Cells(cell.Row, colNum + 1).Value  ' 바로 우측열 셀값

                If colNum Mod 2 = 0 Then
                    ' 짝수열 → 정상
                    normalCount = normalCount + 1
                    normalArr(normalCount, 1) = url
                    normalArr(normalCount, 2) = pairVal
                Else
                    ' 홀수열 → 오염 의심
                    oddCount = oddCount + 1
                    oddArr(oddCount, 1) = url
                    oddArr(oddCount, 2) = pairVal
                End If
            End If
        End If
    Next cell

    ' 정상 출력 H11부터
    outRow = 11
    If normalCount > 0 Then
        Dim i As Long
        For i = 1 To normalCount
            wsOutput.Cells(outRow, 8).Value = normalArr(i, 1)
            wsOutput.Cells(outRow, 9).Value = normalArr(i, 2)
            outRow = outRow + 1
        Next i
    End If

    ' 한줄 띄고 오염 출력
    If oddCount > 0 Then
        outRow = outRow + 1  ' 한줄 띄기
        wsOutput.Cells(outRow, 8).Value = "▼ 홀수열 검출 (데이터 오염 의심)"
        outRow = outRow + 1
        For i = 1 To oddCount
            wsOutput.Cells(outRow, 8).Value = oddArr(i, 1)
            wsOutput.Cells(outRow, 9).Value = oddArr(i, 2)
            outRow = outRow + 1
        Next i
    End If

    Application.ScreenUpdating = True

    Dim msg As String
    msg = "완료! 정상 " & normalCount & "개"
    If oddCount > 0 Then
        msg = msg & ", 홀수열(오염의심) " & oddCount & "개"
    End If
    If normalCount = 0 And oddCount = 0 Then
        msg = "'" & keyword & "' 를 포함한 하이퍼링크를 찾지 못했습니다."
    End If
    MsgBox msg

End Sub

