Sub FindHyperlink()
    Dim wsOutput As Worksheet
    Dim ws As Worksheet
    Dim cell As Range
    Dim keyword As String
    Dim outRow As Long

    Set wsOutput = ThisWorkbook.Sheets("W")
    keyword = Trim(wsOutput.Range("E2").Value)

    If keyword = "" Then
        MsgBox "E2에 검색할 주소 문자열을 입력하세요."
        Exit Sub
    End If

    wsOutput.Range("H11:I1000").ClearContents
    outRow = 11

    Application.ScreenUpdating = False

    For Each ws In ThisWorkbook.Sheets
        If ws.Name <> "W" Then
            For Each cell In ws.UsedRange
                If cell.Hyperlinks.Count > 0 Then
                    Dim url As String
                    url = cell.Hyperlinks(1).Address
                    If InStr(url, keyword) > 0 Then
                        wsOutput.Cells(outRow, 8).Value = url        ' H열: 웹주소
                        wsOutput.Cells(outRow, 9).Value = cell.Value ' I열: 셀값
                        outRow = outRow + 1
                    End If
                End If
            Next cell
        End If
    Next ws

    Application.ScreenUpdating = True

    If outRow = 11 Then
        MsgBox "'" & keyword & "' 를 포함한 하이퍼링크를 찾지 못했습니다."
    Else
        MsgBox "완료! 총 " & (outRow - 11) & "개 발견"
    End If
End Sub

